# ─── Configuration du Worker (Modèle Économique) ─────────────────────────────
# Fournisseur : openai | anthropic | ollama | bedrock | custom
WORKER_PROVIDER=openai

# Connexion API
WORKER_API_BASE_URL=https://api.openai.com/v1
WORKER_API_KEY=sk-your-api-key-here
WORKER_MODEL_NAME=gpt-4o

# Pour Azure OpenAI ou une API Gateway Azure (APIM), décommentez :
# WORKER_API_BASE_URL=https://your-instance.openai.azure.com/
# WORKER_API_VERSION=2024-12-01-preview
# (La clé API sera automatiquement utilisée comme Ocp-Apim-Subscription-Key si nécessaire)

# ─── Provider de Secours (Optionnel) ─────────────────────────────────────────
# WORKER_FALLBACK_PROVIDER=ollama
# WORKER_FALLBACK_API_BASE_URL=http://localhost:11434
# WORKER_FALLBACK_MODEL_NAME=codellama:34b

# ─── Configuration du Serveur MCP ────────────────────────────────────────────
# Transport : stdio (IDE locaux) | http (serveur distant)
MCP_TRANSPORT=stdio

# Uniquement si MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=8080

# ─── Résilience ──────────────────────────────────────────────────────────────
WORKER_MAX_RETRIES=3
WORKER_TIMEOUT_SECONDS=120
WORKER_MAX_OUTPUT_TOKENS=4096

# ─── Sécurité ────────────────────────────────────────────────────────────────
# Répertoires autorisés pour lecture/écriture (séparés par des virgules)
ALLOWED_PATHS=.

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=nexus_worker.log
METRICS_ENABLED=true

# ─── Prompts (Optionnel) ─────────────────────────────────────────────────────
# Répertoire personnalisé pour surcharger les templates de prompts
# PROMPT_TEMPLATES_DIR=/path/to/custom/templates
